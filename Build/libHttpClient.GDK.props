<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- This file is a replacement for Microsoft.Cpp.Default.Props and Microsoft.Cpp.props for Cpp projects targeting GDK -->

  <Import Condition="'$(HCPathsImported)' != 'true'" Project="libHttpClient.paths.props" />

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|Gaming.Desktop.x64">
      <Configuration>Debug</Configuration>
      <Platform>Gaming.Desktop.x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Gaming.Desktop.x64">
      <Configuration>Release</Configuration>
      <Platform>Gaming.Desktop.x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <DefaultLanguage>en-US</DefaultLanguage>
    <Keyword>Win32Proj</Keyword>
    <PlatformToolset Condition="'$(PlatformToolset)' == '' and $(VisualStudioVersion)==16">v142</PlatformToolset>
    <PlatformToolset Condition="'$(PlatformToolset)' == '' and $(VisualStudioVersion)==17">v143</PlatformToolset>
    <TargetRuntime>Native</TargetRuntime>
    <CharacterSet>Unicode</CharacterSet>
    <GenerateManifest>false</GenerateManifest>
    <WindowsTargetPlatformVersion Condition="'$(Platform)' != 'Gaming.Xbox.Scarlett.x64'">10.0.19041.0</WindowsTargetPlatformVersion>
    <WindowsTargetPlatformVersion Condition="'$(Platform)' == 'Gaming.Xbox.Scarlett.x64'">10.0.26100.0</WindowsTargetPlatformVersion>
    <PreferredToolArchitecture>x64</PreferredToolArchitecture>
  </PropertyGroup>

  <!-- GDK Build without install props files overrides VCTargetsPath and a few other properties so it needs to be included before the default props -->
  <Import Project="libHttpClient.gdk.bwoi.props" />

  <!-- Include the Default MS props -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <WholeProgramOptimization>false</WholeProgramOptimization>
    <SpectreMitigation Condition="'$(SpectreMitigation)'==''">Spectre</SpectreMitigation>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <UseDebugLibraries>true</UseDebugLibraries>
    <LinkIncremental>true</LinkIncremental>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <UseDebugLibraries>false</UseDebugLibraries>
    <LinkIncremental>false</LinkIncremental>
  </PropertyGroup>

  <!-- Include the main MS props -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- If available, import Gamecore props to access GDK path variables (GrdkLibDir, GxdkLibDir, etc.) -->
  <Import Condition="Exists('$(XboxBumblelionRoot)\build\props\CommonProperties.props')" Project="$(XboxBumblelionRoot)\build\props\CommonProperties.props" />
  <Import Condition="Exists('$(XboxBumblelionRoot)\build\props\platform\GamecoreCommonProperties.props')" Project="$(XboxBumblelionRoot)\build\props\platform\GamecoreCommonProperties.props" />

  <PropertyGroup>
    <LibraryPath>$(Console_SdkLibPath);$(LibraryPath)</LibraryPath>
    <IncludePath>$(Console_SdkIncludeRoot);$(IncludePath)</IncludePath>
  </PropertyGroup>

  <!-- Fallback: synthesize common GDK lib directories when not provided by platform toolset -->
  <PropertyGroup>
    <_GrdkGameKitLibDir Condition="'$(_GrdkGameKitLibDir)'=='' and Exists('$(GameDK)\$(XdkEditionTarget)\GRDK\GameKit\Lib\amd64')">$(GameDK)\$(XdkEditionTarget)\GRDK\GameKit\Lib\amd64</_GrdkGameKitLibDir>
    <_GxdkGameKitLibDir Condition="'$(_GxdkGameKitLibDir)'=='' and Exists('$(GameDK)\$(XdkEditionTarget)\GXDK\GameKit\Lib\amd64')">$(GameDK)\$(XdkEditionTarget)\GXDK\GameKit\Lib\amd64</_GxdkGameKitLibDir>
    <_WindowsLibX64 Condition="'$(_WindowsLibX64)'=='' and Exists('$(GameDK)\$(XdkEditionTarget)\windows\lib\x64')">$(GameDK)\$(XdkEditionTarget)\windows\lib\x64</_WindowsLibX64>
    <_XboxGen9LibX64 Condition="'$(_XboxGen9LibX64)'=='' and Exists('$(GameDK)\$(XdkEditionTarget)\xbox_gen9\lib\x64')">$(GameDK)\$(XdkEditionTarget)\xbox_gen9\lib\x64</_XboxGen9LibX64>
    <_XboxGen8LibX64 Condition="'$(_XboxGen8LibX64)'=='' and Exists('$(GameDK)\$(XdkEditionTarget)\xbox_gen8\lib\x64')">$(GameDK)\$(XdkEditionTarget)\xbox_gen8\lib\x64</_XboxGen8LibX64>
  <!-- Also try absolute paths from GameDKLatest for modern installs -->
  <_GdkWindowsLibX64Latest Condition="'$(_GdkWindowsLibX64Latest)'=='' and '$(GameDKLatest)'!='' and Exists('$(GameDKLatest)windows\lib\x64')">$(GameDKLatest)windows\lib\x64</_GdkWindowsLibX64Latest>
  <_GrdkGameKitLibDirLatest Condition="'$(_GrdkGameKitLibDirLatest)'=='' and '$(GameDKLatest)'!='' and Exists('$(GameDKLatest)GRDK\GameKit\Lib\amd64')">$(GameDKLatest)GRDK\GameKit\Lib\amd64</_GrdkGameKitLibDirLatest>
  <_GxdkGameKitLibDirLatest Condition="'$(_GxdkGameKitLibDirLatest)'=='' and '$(GameDKLatest)'!='' and Exists('$(GameDKLatest)GXDK\GameKit\Lib\amd64')">$(GameDKLatest)GXDK\GameKit\Lib\amd64</_GxdkGameKitLibDirLatest>
  <_XboxGen9LibX64Latest Condition="'$(_XboxGen9LibX64Latest)'=='' and '$(GameDKLatest)'!='' and Exists('$(GameDKLatest)xbox_gen9\lib\x64')">$(GameDKLatest)xbox_gen9\lib\x64</_XboxGen9LibX64Latest>
  <_XboxGen8LibX64Latest Condition="'$(_XboxGen8LibX64Latest)'=='' and '$(GameDKLatest)'!='' and Exists('$(GameDKLatest)xbox_gen8\lib\x64')">$(GameDKLatest)xbox_gen8\lib\x64</_XboxGen8LibX64Latest>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <Link>
      <!-- Prefer provided Console_SdkLibPath/GrdkLibDir/GxdkLibDir; fall back to synthesized dirs -->
  <AdditionalLibraryDirectories>$(Console_SdkLibPath);$(GrdkLibDir);$(GxdkLibDir);$(_GrdkGameKitLibDir);$(_GxdkGameKitLibDir);$(_WindowsLibX64);$(_XboxGen9LibX64);$(_XboxGen8LibX64);$(_GdkWindowsLibX64Latest);$(_GrdkGameKitLibDirLatest);$(_GxdkGameKitLibDirLatest);$(_XboxGen9LibX64Latest);$(_XboxGen8LibX64Latest);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <SupportJustMyCode>false</SupportJustMyCode>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <PreprocessorDefinitions>__WRL_NO_DEFAULT_LIB__;_LIB;$(libHttpClientDefine);%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalOptions>/bigobj %(AdditionalOptions)</AdditionalOptions>
      <LanguageStandard>stdcpp17</LanguageStandard>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>DebugFull</GenerateDebugInformation>
      <GenerateWindowsMetadata>false</GenerateWindowsMetadata>
      <FullProgramDatabaseFile Condition="'$(Configuration)'=='Debug'">true</FullProgramDatabaseFile>
      <AdditionalDependencies>$(Console_Libs);%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Lib>
      <AdditionalOptions>/ignore:4099 /ignore:4264 %(AdditionalOptions)</AdditionalOptions>
    </Lib>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalOptions Condition="'$(PlatformToolset)'!='v141'">/guard:ehcont %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <FullProgramDatabaseFile>true</FullProgramDatabaseFile>
      <AdditionalOptions Condition="'$(PlatformToolset)'!='v141'">/guard:ehcont %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>

  <!--Configure build output directories-->
  <PropertyGroup>
    <OutDir>$(HCOutRoot)\$(Platform)\$(Configuration)\$(MSBuildProjectName)\</OutDir>
    <IntDir>$(HCIntRoot)\$(Platform)\$(Configuration)\$(MSBuildProjectName)\</IntDir>
  </PropertyGroup>

</Project>

<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{66365E18-7B53-44BF-A348-6735058E359E}</ProjectGuid>
    <ConfigurationType>StaticLibrary</ConfigurationType>
    <PlatformToolset>v142</PlatformToolset>
    <WindowsTargetPlatformVersion>10.0.19041.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$([MSBuild]::GetPathOfFileAbove(libHttpClient.GDK.props))" />
  <!-- Detect GDK layout and set paths accordingly: legacy GRDK vs newer windows layout -->
  <PropertyGroup Condition="'$(_GdkLikePlatform)'=='true'">
    <_GdkWindowsLibFile>$(GameDKLatest)windows\lib\x64\xgameruntime.lib</_GdkWindowsLibFile>
    <GDKLegacyLayout Condition="'$(GDKLegacyLayout)'=='' and !Exists('$(_GdkWindowsLibFile)')">true</GDKLegacyLayout>
    <GDKLegacyLayout Condition="'$(GDKLegacyLayout)'=='' and Exists('$(_GdkWindowsLibFile)')">false</GDKLegacyLayout>

    <Console_SdkIncludeRoot Condition="'$(GDKLegacyLayout)'=='true'">$(GameDKLatest)GRDK\include</Console_SdkIncludeRoot>
    <Console_SdkLibPath Condition="'$(GDKLegacyLayout)'=='true'">$(GameDKLatest)GRDK\lib\x64</Console_SdkLibPath>
    <Console_SdkIncludeRoot Condition="'$(GDKLegacyLayout)'=='false'">$(GameDKLatest)windows\include</Console_SdkIncludeRoot>
    <Console_SdkLibPath Condition="'$(GDKLegacyLayout)'=='false'">$(GameDKLatest)windows\lib\x64</Console_SdkLibPath>
  </PropertyGroup>
  <Import Project="$(HCBuildRoot)\libHttpClient.Common\libHttpClient.Common.vcxitems" Label="Shared" />
  <Import Project="$(HCBuildRoot)\libHttpClient.GDK.Shared\libHttpClient.GDK.Shared.vcxitems" Label="Shared" />
  <Import Condition="'$(HCNoZlib)' != 'true'" Project="$(HCBuildRoot)\libHttpClient.Zlib\libHttpClient.Zlib.vcxitems" Label="Shared" />
  <!-- For legacy layout builds, avoid linking XCurl.lib which may not exist -->
  <ItemDefinitionGroup Condition="'$(GDKLegacyLayout)'=='true'">
    <Link>
      <AdditionalDependencies>$(Console_Libs);%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(HCRoot)\External\curl\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <AdditionalOptions>/Zi /guard:cf %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <AdditionalOptions>/Zi /guard:cf %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>